<UserControl
  x:Class="VExplorer.App.Features.Search.SearchFilterBar"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}"
>
  <Border BorderBrush="#0078D4" BorderThickness="0,1,0,0" Padding="4,3">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <TextBlock
        Grid.Column="0"
        Text="{Binding Prefix}"
        FontFamily="Consolas"
        FontWeight="Bold"
        VerticalAlignment="Center"
        Margin="2,0,6,0"
      />

      <TextBox
        x:Name="QueryInput"
        Grid.Column="1"
        Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        PreviewKeyDown="QueryInput_PreviewKeyDown"
        IsVisibleChanged="QueryInput_IsVisibleChanged"
        FontFamily="Consolas"
        BorderThickness="0"
        Background="Transparent"
        VerticalContentAlignment="Center"
      />
    </Grid>
  </Border>
</UserControl>
