<UserControl
  x:Class="VExplorer.App.Features.Tabs.TabBar"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
>
  <Border
    Background="{DynamicResource TabBarBackground}"
    BorderBrush="{DynamicResource AccentBrush}"
    BorderThickness="0,0,0,1"
  >
    <DockPanel LastChildFill="True">
      <!-- Dark-mode toggle pinned to the right end of the tab-bar row. -->
      <Button
        DockPanel.Dock="Right"
        Style="{StaticResource IconButton}"
        Content="{Binding ThemeIcon}"
        Command="{Binding ToggleThemeCommand}"
        ToolTip="{Binding ThemeToggleTooltip}"
        Margin="2,0,4,0"
        VerticalAlignment="Center"
      />
      <StackPanel Orientation="Horizontal">
        <ItemsControl ItemsSource="{Binding Tabs}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <!-- One tab: click anywhere to activate, click × to close. -->
              <Border
                Margin="2,3,0,0"
                Padding="8,3,4,3"
                CornerRadius="4,4,0,0"
                MouseLeftButtonDown="Tab_MouseLeftButtonDown"
                PreviewMouseMove="Tab_PreviewMouseMove"
                AllowDrop="True"
                DragOver="Tab_DragOver"
                Drop="Tab_Drop"
                Cursor="Hand"
              >
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource TabInactiveBackground}" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter
                          Property="Background"
                          Value="{DynamicResource TabActiveBackground}"
                        />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                  <!-- "[N]" while idle; a small rotating arc while the tab is loading. -->
                  <Grid Margin="0,0,4,0" VerticalAlignment="Center">
                    <TextBlock
                      Text="{Binding Number, StringFormat='[{0}]'}"
                      Foreground="{DynamicResource SecondaryForegroundBrush}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"
                    />
                    <Path
                      Width="12"
                      Height="12"
                      Stroke="{DynamicResource AccentBrush}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 6,0.5 A 5.5,5.5 0 1 1 0.5,6"
                      RenderTransformOrigin="0.5,0.5"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                    >
                      <Path.RenderTransform>
                        <RotateTransform Angle="0" />
                      </Path.RenderTransform>
                      <Path.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                          <BeginStoryboard>
                            <Storyboard>
                              <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                From="0"
                                To="360"
                                Duration="0:0:0.9"
                                RepeatBehavior="Forever"
                              />
                            </Storyboard>
                          </BeginStoryboard>
                        </EventTrigger>
                      </Path.Triggers>
                    </Path>
                  </Grid>
                  <TextBlock
                    Text="{Binding Title}"
                    MaxWidth="160"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center"
                  />
                  <Button
                    Style="{StaticResource FlatButton}"
                    Content="✕"
                    Command="{Binding CloseCommand}"
                    Margin="6,0,0,0"
                    Padding="3,0"
                    FontSize="10"
                    VerticalAlignment="Center"
                    ToolTip="Close tab"
                  />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <!-- New tab. -->
        <Button
          Style="{StaticResource FlatButton}"
          Content="+"
          Command="{Binding NewTabCommand}"
          Margin="4,3,0,0"
          Padding="8,2"
          FontWeight="Bold"
          VerticalAlignment="Center"
          ToolTip="New tab (Ctrl+T)"
        />
      </StackPanel>
    </DockPanel>
  </Border>
</UserControl>
