<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!--
    Dark theme palette (Windows 10 dark style). Same keys as Theme.Light.xaml.
    Dimmed text is kept light enough to stay legible on the dark surface.
  -->
  <!-- Surfaces / text -->
  <SolidColorBrush x:Key="WindowBackground" Color="#1F1F1F" />
  <SolidColorBrush x:Key="SurfaceBackground" Color="#252526" />
  <SolidColorBrush x:Key="InputBackground" Color="#333333" />
  <SolidColorBrush x:Key="ForegroundBrush" Color="#E6E6E6" />
  <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#9E9E9E" />
  <SolidColorBrush x:Key="DimmedForegroundBrush" Color="#808080" />
  <!-- Accent / selection -->
  <SolidColorBrush x:Key="AccentBrush" Color="#3B9CFF" />
  <SolidColorBrush x:Key="SelectionBrush" Color="#0A6CC3" />
  <SolidColorBrush x:Key="SelectionTextBrush" Color="White" />
  <SolidColorBrush x:Key="MultiSelectBrush" Color="#173B5E" />
  <SolidColorBrush x:Key="HoverBrush" Color="#2A2D2E" />
  <!-- Borders / dividers -->
  <SolidColorBrush x:Key="ControlBorderBrush" Color="#3C3C3C" />
  <SolidColorBrush x:Key="SplitterBrush" Color="#3C3C3C" />
  <!-- Tabs -->
  <SolidColorBrush x:Key="TabBarBackground" Color="#2D2D2D" />
  <SolidColorBrush x:Key="TabInactiveBackground" Color="#2D2D2D" />
  <SolidColorBrush x:Key="TabActiveBackground" Color="#1F1F1F" />
  <!-- Status bar -->
  <SolidColorBrush x:Key="StatusBarBackground" Color="#252526" />
  <!-- Buttons -->
  <SolidColorBrush x:Key="IconButtonForeground" Color="#CCCCCC" />
  <!-- Context menu -->
  <SolidColorBrush x:Key="MenuBackground" Color="#2D2D2D" />
  <SolidColorBrush x:Key="MenuBorderBrush" Color="#454545" />
  <SolidColorBrush x:Key="MenuSeparatorBrush" Color="#3C3C3C" />
  <SolidColorBrush x:Key="MenuDisabledForeground" Color="#6D6D6D" />
  <SolidColorBrush x:Key="SubmenuArrowBrush" Color="#9E9E9E" />
  <!-- Semantic status colours -->
  <SolidColorBrush x:Key="ErrorBrush" Color="#F47C7C" />
  <SolidColorBrush x:Key="WarningBrush" Color="#E0A24E" />
  <SolidColorBrush x:Key="SuccessBrush" Color="#6CCB5F" />
  <!-- Scrollbar -->
  <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#4D4D4D" />
  <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#6A6A6A" />
  <!-- SEARCH / FILTER match highlight (looked up from HighlightBehavior). -->
  <SolidColorBrush x:Key="MatchHighlightBackground" Color="#C9A227" />
  <SolidColorBrush x:Key="MatchHighlightForeground" Color="#000000" />
  <!-- Selection brushes for the built-in TreeView / ListBox (completion popup,
       context menu) templates, which honour these system keys. -->
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0A6CC3" />
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
  <SolidColorBrush
    x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
    Color="#0A6CC3"
  />
  <SolidColorBrush
    x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
    Color="White"
  />
</ResourceDictionary>
