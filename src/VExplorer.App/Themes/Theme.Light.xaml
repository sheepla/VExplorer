<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!--
    Light theme palette. Keys are semantic (not colour-named) and mirrored
    one-for-one in Theme.Dark.xaml so the active theme can be swapped at runtime.
    Controls reference these exclusively via DynamicResource.
  -->
  <!-- Surfaces / text -->
  <SolidColorBrush x:Key="WindowBackground" Color="White" />
  <SolidColorBrush x:Key="SurfaceBackground" Color="White" />
  <SolidColorBrush x:Key="InputBackground" Color="White" />
  <SolidColorBrush x:Key="ForegroundBrush" Color="#1A1A1A" />
  <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#666666" />
  <SolidColorBrush x:Key="DimmedForegroundBrush" Color="#8A8A8A" />
  <!-- Accent / selection -->
  <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
  <SolidColorBrush x:Key="SelectionBrush" Color="#0078D7" />
  <SolidColorBrush x:Key="SelectionTextBrush" Color="White" />
  <SolidColorBrush x:Key="MultiSelectBrush" Color="#CCE4F7" />
  <SolidColorBrush x:Key="HoverBrush" Color="#E8F1FB" />
  <!-- Borders / dividers -->
  <SolidColorBrush x:Key="ControlBorderBrush" Color="#ADADAD" />
  <SolidColorBrush x:Key="SplitterBrush" Color="#DDDDDD" />
  <!-- Tabs -->
  <SolidColorBrush x:Key="TabBarBackground" Color="#F0F0F0" />
  <SolidColorBrush x:Key="TabInactiveBackground" Color="#E1E1E1" />
  <SolidColorBrush x:Key="TabActiveBackground" Color="White" />
  <!-- Status bar -->
  <SolidColorBrush x:Key="StatusBarBackground" Color="#F0F0F0" />
  <!-- Buttons -->
  <SolidColorBrush x:Key="IconButtonForeground" Color="#444444" />
  <!-- Context menu -->
  <SolidColorBrush x:Key="MenuBackground" Color="White" />
  <SolidColorBrush x:Key="MenuBorderBrush" Color="#999999" />
  <SolidColorBrush x:Key="MenuSeparatorBrush" Color="#D0D0D0" />
  <SolidColorBrush x:Key="MenuDisabledForeground" Color="#9A9A9A" />
  <SolidColorBrush x:Key="SubmenuArrowBrush" Color="#888888" />
  <!-- Semantic status colours -->
  <SolidColorBrush x:Key="ErrorBrush" Color="#CC3333" />
  <SolidColorBrush x:Key="WarningBrush" Color="#B26B00" />
  <SolidColorBrush x:Key="SuccessBrush" Color="#107C10" />
  <!-- Scrollbar -->
  <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#C8C8C8" />
  <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#A8A8A8" />
  <!-- SEARCH / FILTER match highlight (looked up from HighlightBehavior). -->
  <SolidColorBrush x:Key="MatchHighlightBackground" Color="#FFF176" />
  <SolidColorBrush x:Key="MatchHighlightForeground" Color="#000000" />
  <!-- Selection brushes for the built-in TreeView / ListBox (completion popup,
       context menu) templates, which honour these system keys. -->
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7" />
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
  <SolidColorBrush
    x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
    Color="#0078D7"
  />
  <SolidColorBrush
    x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
    Color="White"
  />
</ResourceDictionary>
